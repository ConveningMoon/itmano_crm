# Copy to .env.local for local overrides (never commit .env.local).
# This demo app runs without env vars; add keys here when you wire auth/APIs.

# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase configuration (Phase 2)
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Server-only — never prefix with NEXT_PUBLIC_. Used by server components to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# JWT secret — used ONLY by the RLS test suite to mint user-scoped tokens.
# Find it at: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
# Never commit the actual value.
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Vercel Cron authentication (Phase 2+)
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# Resend (Phase 3)
# Cuenta LEGACY (A&J / Adriana). Los tenants con tenants.resend_account = 'aj'
# envían desde esta cuenta — no se toca.
# Get from: Resend Dashboard → API Keys
RESEND_API_KEY=re_your-api-key-here
# Cuenta de ITMANO (migración 065). La usan el tenant Test y todos los futuros
# (tenants.resend_account = 'itmano'), y la gestión de dominios del panel super
# admin. Si falta, el envío cae a la cuenta legacy con un aviso en logs.
RESEND_API_KEY_ITMANO=re_your-itmano-api-key-here
# Get from: Resend Dashboard → Webhooks → (after creating the endpoint) → Signing Secret
# Value starts with whsec_
RESEND_WEBHOOK_SECRET=whsec_your-webhook-secret-here
# Unsubscribe link HMAC signing secret (Phase 3)
# Generate with: openssl rand -hex 32
UNSUBSCRIBE_SECRET=your-unsubscribe-secret-here

# Telegram Bot (Phase 3)
# Get from: @BotFather → /newbot or /mybots
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Webhook secret for /api/notifications/dispatch — generated with: openssl rand -hex 32
# Must also be set as a DB parameter (see migration 018 comments)
NOTIFICATIONS_WEBHOOK_SECRET=your-notifications-webhook-secret-here

# Contact Us webhook (Phase 3) — generic/backup endpoint
# Shared secret sent in the `x-contact-secret` header when POSTing to
# /api/contact/[publicId]/submit.
# Generate with: openssl rand -hex 32
CONTACT_WEBHOOK_SECRET=your-contact-webhook-secret-here

# Native Webflow webhook (Phase 3)
# Secret from the Webflow webhook (Site settings → Forms → Webhooks). Used to
# validate the x-webflow-signature HMAC on /api/webhooks/webflow/[publicId].
WEBFLOW_WEBHOOK_SECRET=your-webflow-webhook-secret-here
# Optional: the exact Webflow form name the endpoint processes (default "Contact Us").
WEBFLOW_CONTACT_FORM_NAME=Contact Us

# Los formularios de contacto (landing) y soporte (CRM) ya NO usan email:
# se guardan como platform_requests (migración 057) y el super_admin los
# gestiona en /solicitudes, con aviso por Telegram. No requieren env vars.

# Anthropic API (Phase D — "Crear con IA": propiedades desde PDF)
# Server-only. Used by src/app/(dashboard)/properties/ai-actions.ts to extract a
# listing's data from its PDF with Claude. Get one at console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Google AI / Gemini (Carousel Engine — solo super_admin, fase de prueba)
# Server-only. Used by src/lib/carousels/gemini.ts for trend research
# (gemini-2.5-flash + google_search grounding) and editorial backgrounds
# (gemini-2.5-flash-image, "Nano Banana"). Get one at aistudio.google.com.
GOOGLE_AI_API_KEY=your-google-ai-studio-api-key-here
